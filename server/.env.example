# ─── ImageKE Backend (.env) ────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Your Paystack SECRET key (starts with sk_test_ or sk_live_)
# Found at: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins (no trailing slash)
# Local:      http://localhost:5173
# Production: https://imageke.com,https://imageke-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:5173

# Port (Render sets this automatically — do not change for production)
PORT=5000

# ── Keep-Alive Ping Secret ────────────────────────────────────────────────────
# A strong random token used to authenticate cron-job calls to GET /api/ping.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this same value as the token in your cron job (cron-job.org / UptimeRobot / GitHub Actions).
# If left unset, the /api/ping endpoint will still work but will log a warning.
PING_SECRET=your_strong_random_token_here

# ── Subscription Token Secret ──────────────────────────────────────────────────
# A secure, private key used to sign and verify customer monthly subscription tokens.
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this secret. If this key changes, all active client-side subscription tokens will be invalidated.
TOKEN_SECRET=your_secure_subscription_signing_key_here
