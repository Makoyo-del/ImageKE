# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values BEFORE running `npm run build`.
# The built dist/ folder is then uploaded to Hostinger.

# Your Paystack PUBLIC key (starts with pk_test_ or pk_live_)
# Get it from: https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Render backend API URL (no trailing slash)
# After deploying the backend on Render, paste its URL here.
# Example: https://imageke-api.onrender.com
VITE_API_URL=https://imageke-api.onrender.com

# ─── Gemini API Key for ATS Parsing ───────────────────────────────────────────
# Get a free API key from Google AI Studio: https://aistudio.google.com/
# This is used for advanced client-side resume parsing and compliance checks.
VITE_GEMINI_API_KEY=your_free_gemini_api_key_here

