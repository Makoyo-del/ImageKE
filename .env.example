# ─── Frontend (.env for local development only) ────────────────────────────────
# In production, the frontend is built into dist/ and served by the Express server.
# These variables are only needed when running `npm run dev` locally.

# Your Paystack PUBLIC key (starts with pk_test_ or pk_live_)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend server URL for local dev (leave empty or remove for production)
# When deployed, the frontend and backend are on the same domain — no URL needed.
VITE_API_URL=http://localhost:5000
